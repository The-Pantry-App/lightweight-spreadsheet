{
  "name": "the-pantry/lightweight-spreadsheet",
  "description": "A lightweight php library for reading spreadsheet files",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.4",
    "ext-xmlreader": "*",
    "ext-zip": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^13.2",
    "symfony/var-dumper": "^8.1",
    "phpstan/phpstan": "^2.2",
    "friendsofphp/php-cs-fixer": "^3.95"
  },
  "autoload": {
    "psr-4": {
      "ThePantry\\LightweightSpreadsheet\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "ThePantry\\LightweightSpreadsheet\\Tests\\": "tests/"
    }
  },
  "authors": [
    {
      "name": "Jonah Böther",
      "email": "mail@jbtcd.me"
    }
  ],
  "scripts": {
    "test": "vendor/bin/phpunit",
    "analyse": "vendor/bin/phpstan analyse",
    "cs-check": "vendor/bin/php-cs-fixer fix --dry-run --diff --allow-risky=yes",
    "cs-fix": "vendor/bin/php-cs-fixer fix --allow-risky=yes"
  },
  "minimum-stability": "stable"
}
